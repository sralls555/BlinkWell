{
  "expo": {
    "name": "BlinkWell",
    "slug": "blinkwell",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#111827"
    },
    "newArchEnabled": false,
    "plugins": [
      "expo-notifications",
      "react-native-vision-camera",
      "expo-font",
      "./plugins/withForegroundService"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "BlinkWell uses the front camera to detect your blink rate and protect your eyes from strain. No video is stored or uploaded."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.blinkwell"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "01059236-dd04-45ef-9024-f35c6e4dfdd7"
      }
    }
  }
}
